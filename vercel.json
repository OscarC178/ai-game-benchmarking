{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/",                               "destination": "/guide/index.html" },
    { "source": "/paper",                          "destination": "/paper/index.html" },
    { "source": "/paper/",                         "destination": "/paper/index.html" },
    { "source": "/beginners-guide",                "destination": "/guide/beginners-guide.html" },
    { "source": "/beginners-guide/",               "destination": "/guide/beginners-guide.html" },
    { "source": "/api/data",                       "destination": "/guide/data.json" },

    { "source": "/game/v1/:run/:game/:builder",    "destination": "/games/:run/:game/:builder/index.html" },
    { "source": "/game/v1/:run/:game/:builder/",   "destination": "/games/:run/:game/:builder/index.html" },
    { "source": "/game/v2/:run/:game/:builder",    "destination": "/games-v2/builds/:run/:game/:builder/index.html" },
    { "source": "/game/v2/:run/:game/:builder/",   "destination": "/games-v2/builds/:run/:game/:builder/index.html" },

    { "source": "/spec/v1/:run/:game",             "destination": "/games/:run/:game/spec.md" },
    { "source": "/spec/v1/:run/:game/:builder",    "destination": "/games/:run/:game/spec.md" },
    { "source": "/spec/v2/:run/:game",             "destination": "/games-v2/specs/:run/:game/spec.md" },
    { "source": "/spec/v2/:run/:game/:builder",    "destination": "/games-v2/specs/:run/:game/spec.md" }
  ]
}
